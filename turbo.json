{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "codegen": {
      "env": ["DATABASE_URL"],
      "cache": true,
      "outputs": ["src/generated/**"]
    },
    "prepack": {
      "cache": true,
      "persistent": false,
      "outputs": ["dist/**"]
    },
    "build": {
      "env": ["DATABASE_URL", "PUBLIC_API_URL"],
      "dependsOn": ["^build", "codegen", "prepack"],
      "outputs": ["dist/**", "storybook-static/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "env": ["DATABASE_URL", "PUBLIC_API_URL"],
      "persistent": true,
      "cache": false
    },
    "lint": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "cache": false
    },
    "storybook": {}
  }
}
