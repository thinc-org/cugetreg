# Reg Chula scrape scope
SCRAPER_ACADEMIC_YEARS=2568
SCRAPER_STUDY_PROGRAMS=S,T,I
SCRAPER_SEMESTERS=1,2

# Rate limiting
SCRAPER_BATCH_SIZE=25
SCRAPER_DELAY_MS=300
SCRAPER_MAX_RETRIES=10

# Empty = discover ALL courses from 28 faculties
SCRAPER_COURSE_NOS=
# 0 = no limit (full scrape). Use e.g. 20 for a quick test.
SCRAPER_MAX_COURSES=0

# Optional: V1 course description CSV (NOT from Reg Chula — see README)
# Download course_chula_full.csv from team / main branch apps/reg-scraper/data/
COURSE_DESC_PATH=../../data/course_chula_full.csv
OVERRIDES_PATH=../../packages/database/data/overrides.json

# Export targets (comma-separated: json, postgres)
SCRAPER_EXPORTERS=json,postgres

# JSON output (used by @repo/database seed as fallback)
SCRAPER_JSON_OUTPUT=../../packages/database/data/courses.json
SCRAPER_STATUS_OUTPUT=../../packages/database/data/scraper-status.json

# PostgreSQL (same as apps/web and packages/database)
DATABASE_URL=postgresql://cugetreg:cugetreg@localhost:5432/cugetreg
