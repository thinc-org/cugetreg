{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "codegen": {
        "cache": true
    },
    "build": {
        "dependsOn": ["codegen"],
      "outputs": ["dist/**", "storybook-static/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {
        "persistent": true,
        "cache": false
    },
    "test": {
        "cache": false
    },
    "storybook": {},
  }
}
